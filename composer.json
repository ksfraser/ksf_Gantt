{
    "name": "ksfraser/ksf-gantt",
    "description": "A reusable PHP Gantt chart library with HTML/SVG rendering and resource utilization tracking",
    "type": "library",
    "license": "MIT",
    "keywords": ["gantt", "project-management", "chart", "timeline", "resource-utilization"],
    "homepage": "https://github.com/ksfraser/ksf-gantt",
    "autoload": {
        "psr-4": {
            "Ksfraser\\Gantt\\": "src/Ksfraser/Gantt/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Gantt\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}